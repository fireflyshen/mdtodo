<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.fireflyshen.mdtodo</id>
    <name>mdtodo</name>
    <vendor>fireflyshen</vendor>
    <description><![CDATA[
        A simple plugin to toggle Markdown checkboxes between [ ] and [x].
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!-- 1. 这里是扩展点，因为你现在不开发侧边栏或启动任务，保持为空即可 -->
    <extensions defaultExtensionNs="com.intellij">
    </extensions>

    <!-- 2. 重要：actions 必须放在 extensions 之外，直接属于 idea-plugin -->
    <actions>
        <action id="com.github.fireflyshen.mdtodo.ToggleTodo"
                class="com.github.fireflyshen.mdtodo.actions.ToggleTodoAction"
                text="Toggle Markdown Todo">

            <!-- 方案 A：保留 alt，但增加 meta(Command) 作为备选 -->
            <keyboard-shortcut first-keystroke="alt T" keymap="$default"/>
            <keyboard-shortcut first-keystroke="meta shift T" keymap="$default"/>

            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>